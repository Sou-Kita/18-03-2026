{
  "info": {
    "name": "NNPTUD-S4 API (RS256 JWT)",
    "description": "API collection for testing NNPTUD-S4 with RS256 JWT authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"Test@12345\",\n  \"email\": \"testuser@example.com\",\n  \"role\": \"69b0ddec842e41e8160132b8\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (RS256)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"Test@12345\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login and receive RS256 JWT token"
          }
        },
        {
          "name": "Get /me (Requires Auth)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get current logged-in user info. Requires RS256 JWT token in Authorization header."
          }
        },
        {
          "name": "Change Password (Requires Auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldpassword\": \"Test@12345\",\n  \"newpassword\": \"NewTest@54321\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/auth/changepassword",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "auth", "changepassword"]
            },
            "description": "Change user password. Requires RS256 JWT token and valid old password. New password must be strong (min 8 chars, 1 uppercase, 1 lowercase, 1 number, 1 special char)."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
